{
    "makefile.configureOnOpen": true,
    "makefile.loggingLevel": "Verbose",
    "makefile.extensionLog": ".vscode/extension.log",
    "makefile.buildLog": ".vscode/dryout.log",
    "makefile.preConfigureScript": ".vscode/preconfigure.sh",
    "makefile.alwaysPreConfigure": true,
    "C_Cpp.errorSquiggles": "enabled",
    "files.associations": {
        "*.c": "c",
        "array": "c",
        "string": "c",
        "string_view": "c",
        "ranges": "c"
    }
}